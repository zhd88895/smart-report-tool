# 智能报告生成工具 - 环境配置示例

# 服务端口（默认 3001）
PORT=3001

# JWT 签名密钥（必填，请修改为随机字符串）
JWT_SECRET=your-jwt-secret-here

# JWT Token 过期时间（默认 24h）
JWT_EXPIRES_IN=24h

# 数据存储目录（默认 ./data）
DATA_DIR=./data

# 日志输出格式：text 或 json（默认 text）
LOG_FORMAT=text

# 日志文件最大大小（字节，默认 10MB）
LOG_MAX_SIZE=10485760

# 保留的日志文件数量（默认 10）
LOG_MAX_FILES=10

# bcrypt 加密轮数（默认 12）
BCRYPT_ROUNDS=12

# 允许的 CORS 来源，逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
